# =============================================================================
# Real-Time Disaster Prediction Platform — Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=disaster-predict
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=disaster_predict
POSTGRES_USER=disasteruser
POSTGRES_PASSWORD=disasterpass123

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

ELASTICSEARCH_URL=http://localhost:9200

# ── NASA / Satellite APIs ─────────────────────────────────────────────────────
NASA_EARTHDATA_USER=your-earthdata-username
NASA_EARTHDATA_PASS=your-earthdata-password
NASA_FIRMS_API_KEY=your-firms-map-key
SENTINEL_HUB_CLIENT_ID=your-sentinel-client-id
SENTINEL_HUB_CLIENT_SECRET=your-sentinel-secret
GOOGLE_EARTH_ENGINE_KEY=path/to/gee-credentials.json

# ── Weather / Climate APIs ────────────────────────────────────────────────────
CDS_API_KEY=your-copernicus-cds-key
ECMWF_API_KEY=your-ecmwf-key
NOAA_API_KEY=your-noaa-key
OPENWEATHER_API_KEY=your-openweather-key

# ── LLM APIs ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
HUGGINGFACE_TOKEN=your-hf-token
LLM_MODEL=gpt-4-turbo-preview
LOCAL_LLM_URL=http://localhost:11434

# ── Alert Channels ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_FROM=+15005550006
SENDGRID_API_KEY=your-sendgrid-key
TELEGRAM_BOT_TOKEN=your-telegram-token
FCM_SERVER_KEY=your-fcm-key

# ── MLOps ─────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=disaster-prediction
WANDB_API_KEY=your-wandb-key
WANDB_PROJECT=disaster-prediction
DVC_REMOTE=s3://your-bucket/dvc

# ── Cloud ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=disaster-predict-models

AZURE_STORAGE_CONNECTION_STRING=your-azure-conn-string
GOOGLE_APPLICATION_CREDENTIALS=path/to/gcp-creds.json
GCP_PROJECT_ID=your-gcp-project

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_SATELLITE=satellite-data
KAFKA_TOPIC_ALERTS=disaster-alerts
KAFKA_TOPIC_PREDICTIONS=disaster-predictions

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin123
SENTRY_DSN=your-sentry-dsn

# ── ML Training ───────────────────────────────────────────────────────────────
RL_DEVICE=auto
TRAINING_BATCH_SIZE=16
TRAINING_EPOCHS=100
MODEL_D_MODEL=256
MODEL_N_HEADS=8
MODEL_N_LAYERS=6
